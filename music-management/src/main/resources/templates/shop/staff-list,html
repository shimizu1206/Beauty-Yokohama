<!DOCTYPE html>
<html lang="ja" xmlns:th="http://www.thymeleaf.org">

<head th:replace="~{layout :: head(アルバム一覧 )}"></head>

<body>
    <div th:replace="~{layout :: header}"></div>
    <h3>商品一覧 </h3>
    <table>
        <thead>
            <tr>
                <th>名前</th>
                <th>性別</th>
                <th>年齢</th>
                <th>特徴 </th>
                <th>経歴 </th>
                <th>趣味 </th>
                <th>ID </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            <tr th:each="staff : ${staffs}">
                <td><span th:text="${staff.staffId}">staffName</span></td>
                <td><span th:text="${staff.itemName}">gender</span></td>
                <td><span th:text="${staff.age}">age</span>円</td>
                <td><span th:text="${staff.speciaty}">specialty;</td>
                <td><span th:text="${staff.career}">career</span></td>
                <td><span th:text="${staff.hobby}">hobby</span></td>
                <td><span th:text="${staff.hobby}">shopId</span></td>
            </tr>
        </tbody>
    </table>
    <div th:replace="~{layout :: footer}"></div>
</body>

</html>